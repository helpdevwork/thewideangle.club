---
// Credit Cards signature block: comparison-first table + Apply CTA.
interface Props {
  cardName: string;
  issuer: string;
  annualFee: string;
  rewardRate: string;
  bestFor: string;
  applyLink: string;
  disclosureLevel?: 'standard' | 'sponsored';
}

const { cardName, issuer, annualFee, rewardRate, bestFor, applyLink, disclosureLevel } = Astro.props;
---

<section class="card-compare">
  <div class="card-compare-header">
    <div>
      <p class="eyebrow">{issuer}</p>
      <h2>{cardName}</h2>
    </div>
    <a class="btn btn-solid apply-cta" href={applyLink} target="_blank" rel="sponsored nofollow noopener">
      Apply now
    </a>
  </div>

  <table class="compare-table">
    <tbody>
      <tr>
        <th scope="row">Annual fee</th>
        <td>{annualFee}</td>
      </tr>
      <tr>
        <th scope="row">Reward rate</th>
        <td>{rewardRate}</td>
      </tr>
      <tr>
        <th scope="row">Best for</th>
        <td>{bestFor}</td>
      </tr>
    </tbody>
  </table>

  {disclosureLevel === 'sponsored' && <p class="sponsored-tag">Sponsored placement — see our disclosure.</p>}
</section>

<style>
  .card-compare {
    background: var(--bg-elevated);
    border: 1px solid var(--accent);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    margin-block: var(--space-5);
  }

  .card-compare-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .card-compare-header h2 {
    margin: 0;
  }

  .apply-cta {
    background: var(--accent);
    color: var(--accent-contrast);
    border-color: var(--accent);
  }

  .compare-table {
    width: 100%;
    border-collapse: collapse;
  }

  .compare-table tr {
    border-top: 1px solid var(--border);
  }

  .compare-table th,
  .compare-table td {
    text-align: left;
    padding: 0.7rem 0;
    font-size: 0.95rem;
  }

  .compare-table th {
    color: var(--fg-muted);
    font-weight: 500;
    width: 40%;
  }

  .compare-table td {
    font-family: var(--font-display);
    font-weight: 600;
  }

  .sponsored-tag {
    margin-top: var(--space-2);
    margin-bottom: 0;
    font-size: 0.75rem;
    color: var(--fg-muted);
  }
</style>
