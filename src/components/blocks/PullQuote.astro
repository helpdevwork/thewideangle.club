---
// Experiences signature block: narrative pull-quote + sponsorship framing.
interface Props {
  quote: string;
  experienceType: string;
  location: string;
  sponsored?: boolean;
  partner?: string;
}

const { quote, experienceType, location, sponsored, partner } = Astro.props;
---

<section class="pull-quote">
  <p class="pq-meta">{experienceType} · {location}</p>
  <blockquote>&ldquo;{quote}&rdquo;</blockquote>
  {sponsored && (
    <p class="pq-sponsor">In partnership with {partner ?? 'a brand partner'} — see our disclosure.</p>
  )}
</section>

<style>
  .pull-quote {
    margin-block: var(--space-6);
    padding-left: var(--space-4);
    border-left: 3px solid var(--accent);
  }

  .pq-meta {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.75rem;
    color: var(--accent);
    margin-bottom: var(--space-2);
  }

  blockquote {
    margin: 0;
    font-family: Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    line-height: 1.3;
    color: var(--fg);
  }

  .pq-sponsor {
    margin-top: var(--space-3);
    margin-bottom: 0;
    font-size: 0.8rem;
    color: var(--fg-muted);
  }
</style>
