---
// Used in vertical hubs (full accent, inherited from the ancestor
// [data-vertical] scope) and on the homepage (wrapped per-card in its
// own data-vertical scope so the shell stays black & white while each
// card still hints at its vertical's identity).
interface Props {
  href: string;
  title: string;
  description: string;
  image: string;
  imageAlt: string;
  meta?: string;
  tag?: string;
}

const { href, title, description, image, imageAlt, meta, tag } = Astro.props;
---

<a class="post-card card" href={href}>
  <div class="post-card-media">
    <img src={image} alt={imageAlt} loading="lazy" />
    {tag && <span class="post-card-tag">{tag}</span>}
  </div>
  <div class="post-card-body">
    <h3>{title}</h3>
    <p>{description}</p>
    {meta && <span class="post-card-meta">{meta}</span>}
  </div>
</a>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .post-card-media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .post-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease);
  }

  .post-card:hover .post-card-media img {
    transform: scale(1.05);
  }

  .post-card-tag {
    position: absolute;
    top: var(--space-2);
    left: var(--space-2);
    background: var(--accent);
    color: var(--accent-contrast, #fff);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: var(--radius-pill);
  }

  .post-card-body {
    padding: var(--space-3) var(--space-3) var(--space-4);
    border-top: 3px solid var(--accent);
  }

  .post-card-body h3 {
    font-size: 1.1rem;
    margin-bottom: 0.4rem;
  }

  .post-card-body p {
    font-size: 0.9rem;
    margin-bottom: var(--space-2);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-meta {
    font-size: 0.75rem;
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
