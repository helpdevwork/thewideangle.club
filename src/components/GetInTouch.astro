---
// Direct-contact block replacing the newsletter capture (per founder
// decision: readers reach us on WhatsApp/Instagram/Email directly rather
// than subscribing to a list). Every placement of this component now
// includes the full form (not just channel buttons) — `variant="full"` is
// channels + form (homepage, hub pages, end of every post, /contact/);
// `variant="popup"` is form-only (no channels, own compact heading) for the
// timed Credit Cards popup. `dense` trims padding for tighter placements
// (end-of-post, end-of-hub) without changing what's shown.
// EmailJS ids are PUBLIC_ — see Documentation/07 §3, same bucket as a GA4
// id: they identify the account, they can't be used to do harm.
import { contact, contactCategories } from '../config/contact';

interface Props {
  variant?: 'full' | 'popup';
  dense?: boolean;
  defaultCategory?: string;
}

const { variant = 'full', dense = false, defaultCategory } = Astro.props;

// Unique per rendered instance so multiple GetInTouch blocks can coexist on
// one page (e.g. the end-of-post block AND the Credit Cards popup) without
// colliding on the same #id.
const uid = Math.random().toString(36).slice(2, 9);
const formId = `git-form-${uid}`;
const statusId = `git-status-${uid}`;
const submitId = `git-submit-${uid}`;

const whatsappHref = `https://wa.me/${contact.whatsappNumber}?text=${encodeURIComponent('Hi thewideangle.club — ')}`;

const emailjsServiceId = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID;
const emailjsTemplateId = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID;
const emailjsPublicKey = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY;
const emailjsReady = Boolean(emailjsServiceId && emailjsTemplateId && emailjsPublicKey);
---

<div class:list={['get-in-touch', { 'get-in-touch--dense': dense, 'get-in-touch--popup': variant === 'popup' }]}>
  {
    variant === 'full' ? (
      <div class="git-copy">
        <p class="eyebrow">Get in touch</p>
        <h3>Talk to us directly</h3>
        <p>
          Doubts about a credit card, a story idea, a partnership — whatever it is, reach us
          however's easiest for you.
        </p>
      </div>
    ) : (
      <div class="git-copy">
        <p class="eyebrow">Get in touch</p>
        <h3>Still exploring credit cards?</h3>
        <p>Tell us what you're trying to figure out — we'll get back to you personally.</p>
      </div>
    )
  }

  {
    variant === 'full' && (
      <div class="git-channels">
        <a class="git-channel" href={whatsappHref} target="_blank" rel="noopener noreferrer">
          <span class="git-channel-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.5 15.2L2 22l4.9-1.5A10 10 0 1 0 12 2Zm0 18.2a8.2 8.2 0 0 1-4.2-1.2l-.3-.2-3 .9.9-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2Zm4.5-6.1c-.2-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1-.2.2-.7.8-.8 1-.2.2-.3.2-.5.1-.2-.1-1-.4-1.9-1.2-.7-.6-1.2-1.4-1.3-1.6-.2-.2 0-.4.1-.5l.4-.4c.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.6-1.5-.8-2-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.2.2-.9.9-.9 2.2s1 2.6 1.1 2.7c.1.2 1.9 3 4.7 4.1.7.3 1.2.4 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.5-.6 1.8-1.2.2-.6.2-1.1.1-1.2-.1-.1-.2-.2-.4-.3Z"/></svg>
          </span>
          <span>
            <strong>WhatsApp</strong>
            <span class="git-channel-detail">{contact.whatsappDisplay}</span>
          </span>
        </a>

        <a class="git-channel" href={contact.instagramUrl} target="_blank" rel="noopener noreferrer">
          <span class="git-channel-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"/></svg>
          </span>
          <span>
            <strong>Instagram</strong>
            <span class="git-channel-detail">{contact.instagramHandle}</span>
          </span>
        </a>

        <a class="git-channel" href={`mailto:${contact.email}`}>
          <span class="git-channel-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="2"/><path d="m3.5 6 8.5 7 8.5-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <span>
            <strong>Email</strong>
            <span class="git-channel-detail">{contact.email}</span>
          </span>
        </a>
      </div>
    )
  }

  {
    variant === 'full' && (
      <p class="git-form-intro">
        Prefer we come to you? Fill this in — whatever it's about, the team will read it and get
        back to you personally.
      </p>
    )
  }

  <form class:list={['git-form', { 'git-form--popup': variant === 'popup' }]} id={formId}>
    <div class="git-form-row">
      <label>
        Name
        <input type="text" name="from_name" required />
      </label>
      <label>
        Email
        <input type="email" name="from_email" required />
      </label>
    </div>
    <div class="git-form-row">
      <label>
        <span>Phone <span class="optional">(optional)</span></span>
        <input type="tel" name="phone" />
      </label>
      <label>
        What's this about?
        <select name="category" required>
          {contactCategories.map((c) => (
            <option value={c} selected={c === defaultCategory}>
              {c}
            </option>
          ))}
        </select>
      </label>
    </div>
    <label class="git-message">
      Message
      <textarea name="message" rows="5" required />
    </label>
    <button type="submit" class="btn btn-solid" id={submitId}>
      Send message
    </button>
    <p class="git-status" id={statusId} role="status" aria-live="polite" />
  </form>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
<script is:inline define:vars={{ emailjsServiceId, emailjsTemplateId, emailjsPublicKey, emailjsReady, formId, statusId, submitId }}>
  (function () {
    function wire() {
      var form = document.getElementById(formId);
      var status = document.getElementById(statusId);
      var submitBtn = document.getElementById(submitId);
      if (!form) return;

      if (emailjsReady && window.emailjs) {
        window.emailjs.init({ publicKey: emailjsPublicKey });
      }

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        if (!emailjsReady || !window.emailjs) {
          status.textContent = "This form isn't connected yet — email us directly instead.";
          return;
        }
        submitBtn.disabled = true;
        status.textContent = 'Sending…';

        var formData = new FormData(form);
        var templateParams = {
          from_name: formData.get('from_name'),
          from_email: formData.get('from_email'),
          phone: formData.get('phone'),
          category: formData.get('category'),
          message: formData.get('message'),
          name: formData.get('from_name'),
          email: formData.get('from_email')
        };

        window.emailjs
          .send(emailjsServiceId, emailjsTemplateId, templateParams)
          .then(function () {
            status.textContent = "Thanks — we'll get back to you soon.";
            form.reset();
            submitBtn.disabled = false;
          })
          .catch(function () {
            status.textContent = 'Something went wrong — try WhatsApp or email us directly.';
            submitBtn.disabled = false;
          });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', wire);
    } else {
      wire();
    }
  })();
</script>

<style>
  .get-in-touch {
    background: var(--inverse-bg);
    color: var(--inverse-fg);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    margin-block: var(--space-6);
  }

  .get-in-touch--dense {
    padding: var(--space-4);
    margin-block: var(--space-5);
  }

  .get-in-touch--popup {
    margin-block: 0;
    border-radius: 0;
  }

  .git-copy h3 {
    color: var(--inverse-fg);
    font-size: 1.4rem;
  }

  .git-copy p {
    color: color-mix(in srgb, var(--inverse-fg) 70%, transparent);
    max-width: 52ch;
  }

  .git-channels {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .git-channel {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3);
    border: 1px solid color-mix(in srgb, var(--inverse-fg) 20%, transparent);
    border-radius: var(--radius-md);
    color: var(--inverse-fg);
    transition: border-color 0.2s var(--ease), transform 0.2s var(--ease);
  }

  .git-channel:hover {
    border-color: var(--inverse-fg);
    transform: translateY(-2px);
  }

  .git-channel-icon {
    flex-shrink: 0;
    display: inline-flex;
  }

  .git-channel strong {
    display: block;
    font-family: var(--font-display);
    font-size: 0.95rem;
  }

  .git-channel-detail {
    display: block;
    font-size: 0.8rem;
    color: color-mix(in srgb, var(--inverse-fg) 65%, transparent);
    word-break: break-word;
  }

  .git-form-intro {
    margin-top: var(--space-5);
    padding-top: var(--space-5);
    border-top: 1px solid color-mix(in srgb, var(--inverse-fg) 15%, transparent);
    color: color-mix(in srgb, var(--inverse-fg) 75%, transparent);
    font-size: 0.9rem;
    max-width: 52ch;
  }

  .git-form {
    margin-top: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .git-form--popup {
    margin-top: var(--space-4);
  }

  .git-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }

  .git-form label,
  .git-message {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.85rem;
  }

  .optional {
    font-weight: 400;
    color: color-mix(in srgb, var(--inverse-fg) 55%, transparent);
  }

  .git-form input,
  .git-form select,
  .git-form textarea {
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-sm);
    border: 1px solid color-mix(in srgb, var(--inverse-fg) 30%, transparent);
    background: transparent;
    color: var(--inverse-fg);
  }

  .git-form select option {
    color: #0a0a0a;
  }

  .git-form button {
    align-self: flex-start;
    background: var(--inverse-fg);
    color: var(--inverse-bg);
    border-color: var(--inverse-fg);
  }

  .git-status:not(:empty) {
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--inverse-fg) 80%, transparent);
  }

  /* Consistent alignment everywhere this renders — narrower breakpoint so
     it also collapses cleanly inside a post's ~68ch measure column and
     inside the (narrower) popup dialog, not just at true mobile widths. */
  @media (max-width: 720px) {
    .get-in-touch {
      padding: var(--space-4);
    }
    .git-form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
