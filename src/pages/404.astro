---
import BaseLayout from '../layouts/BaseLayout.astro';
import { verticalList } from '../config/verticals';
---

<BaseLayout title="Page not found" description="This page doesn't exist on thewideangle.club." noindex>
  <section class="container not-found">
    <p class="eyebrow">404</p>
    <h1>That frame's empty.</h1>
    <p class="measure">The page you're looking for doesn't exist, or has moved. Try one of the verticals below.</p>
    <div class="not-found-links">
      {verticalList.map((v) => <a href={`/${v.id}/`} class="btn btn-ghost">{v.name}</a>)}
    </div>
    <a href="/" class="btn btn-solid home-link">Back to home</a>
  </section>
</BaseLayout>

<style>
  .not-found {
    padding-block: var(--space-8);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .not-found-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
    margin-block: var(--space-5);
  }

  .home-link {
    margin-top: var(--space-3);
  }
</style>
