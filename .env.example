# thewideangle.club — environment variables
# See Documentation/07_Secrets_and_Key_Storage.docx for the full classification.
# Everything below is a PUBLIC id (safe to expose to the browser) — real
# secrets (newsletter API keys, OAuth client secrets, etc.) never go in
# this file at all; they live only in Cloudflare Pages > Settings >
# Environment variables, marked as encrypted.

# GA4 Measurement ID (public) — e.g. G-XXXXXXX
PUBLIC_GA4_ID=

# Umami website ID (public) — a UUID
PUBLIC_UMAMI_ID=
PUBLIC_UMAMI_SRC=

# AdSense publisher ID (public) — e.g. ca-pub-XXXXXXXXXXXXXXXX
# Do not set until the site has been approved (BRD §7 sequencing).
PUBLIC_ADSENSE_CLIENT=

# Cuelinks channel script (public)
PUBLIC_CUELINKS_SRC=

# EmailJS (public) — powers the Get in Touch form (src/components/GetInTouch.astro).
# The public key is designed by EmailJS to be used client-side, same bucket as a GA4 id.
# Get these from emailjs.com after creating a service + template (template text: see README).
PUBLIC_EMAILJS_SERVICE_ID=
PUBLIC_EMAILJS_TEMPLATE_ID=
PUBLIC_EMAILJS_PUBLIC_KEY=
